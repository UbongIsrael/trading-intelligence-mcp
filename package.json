{
  "name": "trading-intelligence-mcp",
  "version": "0.1.0",
  "description": "Trading Intelligence MCP Server - Multi-asset trading data aggregation with technical analysis",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc",
    "build:clean": "rm -rf dist && npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "trading",
    "finance",
    "context-protocol",
    "stocks",
    "crypto"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "node-fetch": "^3.3.2",
    "yahoo-finance2": "^3.13.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
