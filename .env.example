# Environment Configuration for Trading Intelligence MCP

# ===== Server Configuration =====
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ===== Redis Cache Configuration =====
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
# Cache TTL settings (in seconds)
CACHE_TTL_PRICES=300          # 5 minutes for price data
CACHE_TTL_LIQUIDITY=900       # 15 minutes for liquidity zones
CACHE_TTL_FUNDAMENTALS=3600   # 1 hour for fundamental data

# ===== Database Configuration =====
# PostgreSQL for storing historical data and analysis results
DATABASE_URL=postgresql://user:password@localhost:5432/trading_intelligence

# ===== API Keys =====
# Stock Data APIs
YAHOO_FINANCE_API_KEY=
# Alpha Vantage API Key Pool (comma-separated, 5 free keys for parallel DCF)
ALPHA_VANTAGE_API_KEYS=
# Single-key fallback (used if ALPHA_VANTAGE_API_KEYS not set)
ALPHA_VANTAGE_API_KEY=
# Premium key (set to actual key value when you get one, leave empty if none)
ALPHA_VANTAGE_PREMIUM_KEY=
FINNHUB_API_KEY=

# Crypto Data APIs
COINGECKO_API_KEY=
COINMARKETCAP_API_KEY=

# News & Sentiment APIs
NEWS_API_KEY=

# SEC Filings
SEC_USER_AGENT=YourEmail@example.com

# ===== Rate Limiting =====
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ===== Feature Flags =====
ENABLE_CACHING=true
ENABLE_HISTORICAL_DATA=true
ENABLE_NEWS_SENTIMENT=false  # Week 3 feature

# ===== MCP Configuration =====
MCP_SERVER_NAME=trading-intelligence
MCP_SERVER_VERSION=0.1.0
MCP_DESCRIPTION="Trading Intelligence MCP Server"

# ===== External Service URLs =====
# Leave these as defaults unless using custom deployments
YAHOO_FINANCE_BASE_URL=https://query2.finance.yahoo.com
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ===== Monitoring & Logging =====
SENTRY_DSN=
ENABLE_PERFORMANCE_LOGGING=true
